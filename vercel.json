{
  "builds": [
    {
      "src": "cyclebay/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "cyclebay/wsgi.py"
    }
  ],
  "installCommand": "pip install --upgrade pip && pip install psycopg2-binary==2.9.9 && pip install -r requirements.txt"
}